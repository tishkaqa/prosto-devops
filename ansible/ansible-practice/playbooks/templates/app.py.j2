from flask import Flask

app = Flask(__name__)

@app.route('/')
def index():
    return '''
    <html>
        <body>
            <h1>My App v{{ app_version }}</h1>
            <p>Deployed with Ansible!</p>
        </body>
    </html>
    '''

if __name__ == '__main__':
    app.run(host='0.0.0.0', port={{ app_port }})